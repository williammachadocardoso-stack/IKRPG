<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Ficha RPG</title>

  <style>
    body {
      margin: 0;
      background: #111;
      font-family: Arial;
    }

    .sheet {
      position: relative;
      width: 900px;
      height: 1200px;
      background-image: url("ficha.png");
      background-size: cover;
    }

    input {
      position: absolute;
      background: transparent;
      border: none;
      font-size: 16px;
      font-weight: bold;
      color: black;
      outline: none;
    }

    .nome { top: 120px; left: 200px; width: 200px; }
    .classe { top: 170px; left: 200px; width: 200px; }
    .hp { top: 300px; left: 200px; width: 80px; }
    .mana { top: 340px; left: 200px; width: 80px; }
    .forca { top: 380px; left: 200px; width: 80px; }

    button {
      margin: 10px;
    }
  </style>
</head>

<body>

<input id="id" placeholder="ID do personagem">

<button onclick="carregar()">Carregar</button>
<button onclick="salvar()">Salvar</button>

<div class="sheet">

  <input class="nome" id="nome">
  <input class="classe" id="classe">
  <input class="hp" id="hp">
  <input class="mana" id="mana">
  <input class="forca" id="forca">

</div>

<script>
const API = "SUA_URL_DO_SCRIPT_AQUI";

function carregar() {
  const id = document.getElementById("id").value;

  fetch(API + "?id=" + id)
    .then(r => r.json())
    .then(data => {
      document.getElementById("nome").value = data.nome;
      document.getElementById("classe").value = data.classe;
      document.getElementById("hp").value = data.hp;
      document.getElementById("mana").value = data.mana;
      document.getElementById("forca").value = data.forca;
    });
}

function salvar() {
  const data = {
    id: document.getElementById("id").value,
    nome: document.getElementById("nome").value,
    classe: document.getElementById("classe").value,
    hp: document.getElementById("hp").value,
    mana: document.getElementById("mana").value,
    forca: document.getElementById("forca").value
  };

  fetch(API, {
    method: "POST",
    body: JSON.stringify(data)
  });

  alert("Salvo!");
}
</script>

</body>
</html>
